---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="nosotros" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Content -->
      <div class="reveal">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-onetel-black mb-4">
          {t('about.title')}
        </h2>
        <p class="text-lg text-onetel-blue font-medium mb-6">
          {t('about.subtitle')}
        </p>
        <p class="text-onetel-gray-dark leading-relaxed mb-8">
          {t('about.description')}
        </p>

        <!-- Mission & Vision -->
        <div class="space-y-6">
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-12 h-12 bg-onetel-blue/10 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-onetel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-onetel-black mb-2">{t('about.mission.title')}</h3>
              <p class="text-onetel-gray-dark text-sm leading-relaxed">{t('about.mission.text')}</p>
            </div>
          </div>

          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0 w-12 h-12 bg-onetel-orange/10 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-onetel-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-onetel-black mb-2">{t('about.vision.title')}</h3>
              <p class="text-onetel-gray-dark text-sm leading-relaxed">{t('about.vision.text')}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Visual Element -->
      <div class="reveal">
        <div class="relative">
          <!-- Main Image Placeholder -->
          <div class="bg-gradient-to-br from-onetel-gray-light to-gray-200 rounded-2xl aspect-square flex items-center justify-center overflow-hidden">
            <!-- Tech/Industrial Pattern -->
            <div class="absolute inset-0 opacity-10">
              <svg class="w-full h-full" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
                <pattern id="circuit" x="0" y="0" width="50" height="50" patternUnits="userSpaceOnUse">
                  <circle cx="25" cy="25" r="3" fill="#0066CC"/>
                  <line x1="25" y1="0" x2="25" y2="22" stroke="#0066CC" stroke-width="1"/>
                  <line x1="25" y1="28" x2="25" y2="50" stroke="#0066CC" stroke-width="1"/>
                  <line x1="0" y1="25" x2="22" y2="25" stroke="#0066CC" stroke-width="1"/>
                  <line x1="28" y1="25" x2="50" y2="25" stroke="#0066CC" stroke-width="1"/>
                </pattern>
                <rect width="400" height="400" fill="url(#circuit)"/>
              </svg>
            </div>

            <!-- Central Icon -->
            <div class="relative z-10 text-center">
              <div class="w-32 h-32 mx-auto bg-white rounded-2xl shadow-xl flex items-center justify-center mb-6">
                <div class="flex items-center">
                  <span class="text-3xl font-bold text-onetel-black">One</span>
                  <span class="text-3xl font-bold text-onetel-blue">Tel</span>
                </div>
              </div>
              <div class="flex justify-center space-x-4">
                <div class="w-16 h-16 bg-onetel-blue/20 rounded-xl flex items-center justify-center">
                  <svg class="w-8 h-8 text-onetel-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"></path>
                  </svg>
                </div>
                <div class="w-16 h-16 bg-onetel-orange/20 rounded-xl flex items-center justify-center">
                  <svg class="w-8 h-8 text-onetel-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating Badge -->
          <div class="absolute -bottom-6 -right-6 bg-onetel-blue text-white p-6 rounded-2xl shadow-xl">
            <div class="text-3xl font-bold">15+</div>
            <div class="text-sm opacity-80">{lang === 'es' ? 'Años' : 'Years'}</div>
          </div>

          <!-- Location Badge -->
          <div class="absolute -top-4 -left-4 bg-white p-4 rounded-xl shadow-lg flex items-center space-x-2">
            <svg class="w-5 h-5 text-onetel-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span class="text-sm font-medium text-onetel-gray-dark">Doral, FL</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
