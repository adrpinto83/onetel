---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="alianzas" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-onetel-black mb-4">
        {t('alliances.title')}
      </h2>
      <p class="text-lg text-onetel-gray-dark max-w-2xl mx-auto">
        {t('alliances.subtitle')}
      </p>
    </div>

    <!-- Alliance Card -->
    <div class="reveal bg-gradient-to-br from-onetel-gray-light to-white rounded-3xl p-8 lg:p-12 shadow-xl">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Yokogawa Logo & Info -->
        <div>
          <div class="flex items-center mb-6">
            <!-- Yokogawa Logo Placeholder -->
            <div class="bg-white rounded-xl p-4 shadow-md mr-4">
              <svg class="w-40 h-12" viewBox="0 0 200 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                <text x="10" y="35" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#005BAC">YOKOGAWA</text>
              </svg>
            </div>
            <span class="bg-onetel-blue text-white text-xs font-semibold px-3 py-1 rounded-full">
              {lang === 'es' ? 'Partner Oficial' : 'Official Partner'}
            </span>
          </div>

          <h3 class="text-2xl lg:text-3xl font-bold text-onetel-black mb-4">
            {t('alliances.yokogawa.title')}
          </h3>

          <p class="text-onetel-gray-dark leading-relaxed mb-8">
            {t('alliances.yokogawa.description')}
          </p>

          <!-- Certifications -->
          <div class="flex flex-wrap gap-3">
            <span class="bg-onetel-blue/10 text-onetel-blue text-sm font-medium px-4 py-2 rounded-full">
              ISO 9001
            </span>
            <span class="bg-onetel-orange/10 text-onetel-orange text-sm font-medium px-4 py-2 rounded-full">
              IEC 61511
            </span>
            <span class="bg-onetel-black/10 text-onetel-black text-sm font-medium px-4 py-2 rounded-full">
              ISA 84
            </span>
          </div>
        </div>

        <!-- Benefits List -->
        <div class="space-y-6">
          <div class="flex items-start space-x-4 group">
            <div class="flex-shrink-0 w-12 h-12 bg-onetel-blue/10 rounded-xl flex items-center justify-center group-hover:bg-onetel-blue transition-colors">
              <svg class="w-6 h-6 text-onetel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-onetel-black">{lang === 'es' ? 'Alcance Global' : 'Global Reach'}</h4>
              <p class="text-onetel-gray-dark text-sm">{t('alliances.benefit1')}</p>
            </div>
          </div>

          <div class="flex items-start space-x-4 group">
            <div class="flex-shrink-0 w-12 h-12 bg-onetel-orange/10 rounded-xl flex items-center justify-center group-hover:bg-onetel-orange transition-colors">
              <svg class="w-6 h-6 text-onetel-orange group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-onetel-black">{lang === 'es' ? 'Soporte Certificado' : 'Certified Support'}</h4>
              <p class="text-onetel-gray-dark text-sm">{t('alliances.benefit2')}</p>
            </div>
          </div>

          <div class="flex items-start space-x-4 group">
            <div class="flex-shrink-0 w-12 h-12 bg-onetel-blue/10 rounded-xl flex items-center justify-center group-hover:bg-onetel-blue transition-colors">
              <svg class="w-6 h-6 text-onetel-blue group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-onetel-black">{lang === 'es' ? 'Escalabilidad' : 'Scalability'}</h4>
              <p class="text-onetel-gray-dark text-sm">{t('alliances.benefit3')}</p>
            </div>
          </div>

          <div class="flex items-start space-x-4 group">
            <div class="flex-shrink-0 w-12 h-12 bg-onetel-orange/10 rounded-xl flex items-center justify-center group-hover:bg-onetel-orange transition-colors">
              <svg class="w-6 h-6 text-onetel-orange group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path>
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-onetel-black">{lang === 'es' ? 'Integración Total' : 'Full Integration'}</h4>
              <p class="text-onetel-gray-dark text-sm">{t('alliances.benefit4')}</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Industries Served -->
    <div class="mt-16 reveal">
      <h3 class="text-center text-lg font-semibold text-onetel-gray-dark mb-8">
        {lang === 'es' ? 'Industrias que Servimos' : 'Industries We Serve'}
      </h3>
      <div class="flex flex-wrap justify-center gap-4">
        {[
          { es: 'Petróleo y Gas', en: 'Oil & Gas' },
          { es: 'Manufactura', en: 'Manufacturing' },
          { es: 'Energía', en: 'Energy' },
          { es: 'Química', en: 'Chemical' },
          { es: 'Alimentos y Bebidas', en: 'Food & Beverage' },
          { es: 'Farmacéutica', en: 'Pharmaceutical' },
        ].map((industry) => (
          <span class="bg-onetel-gray-light text-onetel-gray-dark px-6 py-3 rounded-full font-medium hover:bg-onetel-blue hover:text-white transition-colors cursor-default">
            {lang === 'es' ? industry.es : industry.en}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
